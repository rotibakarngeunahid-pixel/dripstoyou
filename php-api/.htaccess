# DRIP TO YOU Bali — PHP API .htaccess
# Tambahkan ke semua folder API di cPanel

Options -Indexes
ServerSignature Off

# Blokir akses langsung ke file config dan helpers
<FilesMatch "^(config|helpers)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_reporting 0
</IfModule>
<IfModule mod_php8.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_reporting 0
</IfModule>
