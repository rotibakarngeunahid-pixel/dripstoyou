generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN_OPERASIONAL
  CONTENT_ADMIN
}

enum BookingStatus {
  BARU
  KONFIRMASI
  DIPROSES
  SELESAI
  DIBATALKAN
}

enum BookingSource {
  WEBSITE
  MANUAL_ADMIN
}

enum LocationType {
  VILLA
  HOTEL
  RUMAH
  AIRBNB
  LAINNYA
}

enum LegalPageType {
  PRIVACY_POLICY
  TERMS_CONDITIONS
  MEDICAL_DISCLAIMER
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  CREATE_PRODUCT
  UPDATE_PRODUCT
  DELETE_PRODUCT
  CREATE_BOOKING
  UPDATE_BOOKING_STATUS
  DELETE_BOOKING
  EXPORT_BOOKINGS
  UPDATE_SCHEDULE
  UPDATE_WHATSAPP
  UPDATE_AREA
  UPDATE_LEGAL_PAGE
  UPDATE_ADMIN
  CREATE_ADMIN
  DELETE_ADMIN
  UPDATE_ABOUT
  UPDATE_FAQ
  UPDATE_SOCIAL_LINK
}

enum SocialPlatform {
  WHATSAPP
  INSTAGRAM
  TIKTOK
  FACEBOOK
  GOOGLE_MAPS
  EMAIL
  WEBSITE
  CUSTOM
}

enum SecurityEventType {
  BRUTE_FORCE_LOGIN
  RATE_LIMIT_EXCEEDED
  UNAUTHORIZED_ADMIN
  INVALID_CSRF
  SUSPICIOUS_UPLOAD
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─────────────────────────────────────────────
// ADMIN ACCOUNTS
// ─────────────────────────────────────────────

model Admin {
  id                 String    @id @default(cuid())
  name               String    @db.VarChar(100)
  email              String    @unique @db.VarChar(255)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  role               AdminRole @default(ADMIN_OPERASIONAL)
  isActive           Boolean   @default(true) @map("is_active")
  mfaEnabled         Boolean   @default(false) @map("mfa_enabled")
  mfaSecretEncrypted String?   @map("mfa_secret_encrypted") @db.VarChar(500)
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  sessions            AdminSession[]
  auditLogs           AuditLog[]
  bookingsCreated     Booking[]            @relation("AdminCreatedBooking")
  statusHistories     BookingStatusHistory[]
  securityEvents      SecurityEvent[]
  updatedSiteSettings SiteSetting[]
  updatedLegalPages   LegalPage[]
  blockedDates        BlockedDate[]

  @@map("admins")
}

model AdminSession {
  id               String    @id @default(cuid())
  adminId          String    @map("admin_id")
  sessionTokenHash String    @map("session_token_hash") @db.VarChar(255)
  ipAddressHash    String?   @map("ip_address_hash") @db.VarChar(255)
  userAgentHash    String?   @map("user_agent_hash") @db.VarChar(255)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([sessionTokenHash])
  @@index([adminId])
  @@map("admin_sessions")
}

model LoginAttempt {
  id            String   @id @default(cuid())
  emailHash     String   @map("email_hash") @db.VarChar(255)
  ipAddressHash String   @map("ip_address_hash") @db.VarChar(255)
  success       Boolean  @default(false)
  failureReason String?  @map("failure_reason") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([emailHash, createdAt])
  @@index([ipAddressHash, createdAt])
  @@map("login_attempts")
}

// ─────────────────────────────────────────────
// PRODUCTS / TREATMENTS
// ─────────────────────────────────────────────

model ProductCategory {
  id        String  @id @default(cuid())
  name      String  @db.VarChar(100)
  slug      String  @unique @db.VarChar(100)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  products Product[]

  @@map("product_categories")
}

model Product {
  id               String           @id @default(cuid())
  categoryId       String?          @map("category_id")
  name             String           @db.VarChar(200)
  slug             String           @unique @db.VarChar(200)
  shortDescription String?          @map("short_description") @db.VarChar(500)
  fullDescription  String?          @map("full_description") @db.Text
  priceAmount      Int              @map("price_amount")
  priceLabel       String?          @map("price_label") @db.VarChar(100)
  durationMinutes  Int?             @map("duration_minutes")
  imageUrl         String?          @map("image_url") @db.VarChar(500)
  label            String?          @db.VarChar(50)
  isActive         Boolean          @default(true) @map("is_active")
  showOnHomepage   Boolean          @default(false) @map("show_on_homepage")
  homepageOrder    Int              @default(0) @map("homepage_order")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  benefits ProductBenefit[]
  faqs     ProductFaq[]
  bookings Booking[]

  @@index([isActive, showOnHomepage])
  @@index([slug])
  @@map("products")
}

model ProductBenefit {
  id          String @id @default(cuid())
  productId   String @map("product_id")
  benefitText String @map("benefit_text") @db.VarChar(500)
  sortOrder   Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_benefits")
}

model ProductFaq {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  question  String  @db.VarChar(500)
  answer    String  @db.Text
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_faqs")
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id                     String        @id @default(cuid())
  bookingCode            String        @unique @map("booking_code") @db.VarChar(20)
  productId              String        @map("product_id")
  customerName           String        @map("customer_name") @db.VarChar(100)
  customerPhoneEncrypted String        @map("customer_phone_encrypted") @db.VarChar(500)
  customerPhoneLast4     String        @map("customer_phone_last4") @db.VarChar(4)
  bookingDate            DateTime      @map("booking_date") @db.Date
  bookingTime            String        @map("booking_time") @db.VarChar(5)
  peopleCount            Int           @default(1) @map("people_count")
  locationType           LocationType  @map("location_type")
  serviceAreaId          String?       @map("service_area_id")
  addressEncrypted       String        @map("address_encrypted") @db.Text
  notesEncrypted         String?       @map("notes_encrypted") @db.Text
  status                 BookingStatus @default(BARU)
  source                 BookingSource @default(WEBSITE)
  createdByAdminId       String?       @map("created_by_admin_id")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  product       Product                @relation(fields: [productId], references: [id])
  serviceArea   ServiceArea?           @relation(fields: [serviceAreaId], references: [id])
  createdBy     Admin?                 @relation("AdminCreatedBooking", fields: [createdByAdminId], references: [id])
  statusHistory BookingStatusHistory[]

  @@index([status, bookingDate])
  @@index([customerPhoneLast4])
  @@index([bookingDate])
  @@map("bookings")
}

model BookingStatusHistory {
  id               String        @id @default(cuid())
  bookingId        String        @map("booking_id")
  oldStatus        BookingStatus @map("old_status")
  newStatus        BookingStatus @map("new_status")
  changedByAdminId String?       @map("changed_by_admin_id")
  note             String?       @db.VarChar(500)
  createdAt        DateTime      @default(now()) @map("created_at")

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy Admin?  @relation(fields: [changedByAdminId], references: [id])

  @@map("booking_status_history")
}

// ─────────────────────────────────────────────
// SCHEDULE
// ─────────────────────────────────────────────

model ScheduleSetting {
  id                   String  @id @default(cuid())
  dayOfWeek            Int     @map("day_of_week")
  isOpen               Boolean @default(true) @map("is_open")
  openTime             String  @default("08:00") @map("open_time") @db.VarChar(5)
  closeTime            String  @default("22:00") @map("close_time") @db.VarChar(5)
  slotDurationMinutes  Int     @default(60) @map("slot_duration_minutes")
  maxBookingsPerSlot   Int     @default(3) @map("max_bookings_per_slot")
  minPrebookingMinutes Int     @default(120) @map("min_prebooking_minutes")

  @@unique([dayOfWeek])
  @@map("schedule_settings")
}

model BlockedDate {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  reason           String?  @db.VarChar(200)
  isFullDay        Boolean  @default(true) @map("is_full_day")
  startTime        String?  @map("start_time") @db.VarChar(5)
  endTime          String?  @map("end_time") @db.VarChar(5)
  createdByAdminId String?  @map("created_by_admin_id")
  createdAt        DateTime @default(now()) @map("created_at")

  createdBy Admin? @relation(fields: [createdByAdminId], references: [id])

  @@index([date])
  @@map("blocked_dates")
}

// ─────────────────────────────────────────────
// SERVICE AREAS
// ─────────────────────────────────────────────

model ServiceArea {
  id                      String  @id @default(cuid())
  name                    String  @db.VarChar(100)
  slug                    String  @unique @db.VarChar(100)
  isActive                Boolean @default(true) @map("is_active")
  estimatedArrivalMinutes Int?    @map("estimated_arrival_minutes")
  extraFeeAmount          Int?    @map("extra_fee_amount")
  note                    String? @db.VarChar(500)
  sortOrder               Int     @default(0) @map("sort_order")

  bookings Booking[]

  @@map("service_areas")
}

// ─────────────────────────────────────────────
// SITE SETTINGS
// ─────────────────────────────────────────────

model SiteSetting {
  key                  String   @id @db.VarChar(100)
  valueEncryptedOrJson String   @map("value_encrypted_or_json") @db.Text
  updatedByAdminId     String?  @map("updated_by_admin_id")
  updatedAt            DateTime @updatedAt @map("updated_at")

  updatedBy Admin? @relation(fields: [updatedByAdminId], references: [id])

  @@map("site_settings")
}

// ─────────────────────────────────────────────
// CONTENT
// ─────────────────────────────────────────────

model Faq {
  id        String  @id @default(cuid())
  category  String  @default("General") @db.VarChar(100)
  question  String  @db.VarChar(500)
  answer    String  @db.Text
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("faqs")
}

model SocialLink {
  id            String         @id @default(cuid())
  platform      SocialPlatform
  label         String         @db.VarChar(100)
  value         String         @db.VarChar(500)
  normalizedUrl String?        @map("normalized_url") @db.VarChar(500)
  isActive      Boolean        @default(true) @map("is_active")
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("social_links")
}

model Testimonial {
  id           String  @id @default(cuid())
  customerName String  @map("customer_name") @db.VarChar(100)
  rating       Int     @default(5)
  content      String  @db.Text
  imageUrl     String? @map("image_url") @db.VarChar(500)
  treatmentTag String? @map("treatment_tag") @db.VarChar(100)
  isActive     Boolean @default(true) @map("is_active")
  sortOrder    Int     @default(0) @map("sort_order")

  @@map("testimonials")
}

model GalleryItem {
  id        String  @id @default(cuid())
  title     String? @db.VarChar(200)
  imageUrl  String  @map("image_url") @db.VarChar(500)
  altText   String? @map("alt_text") @db.VarChar(300)
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  @@map("gallery_items")
}

model LegalPage {
  id               String        @id @default(cuid())
  type             LegalPageType @unique
  title            String        @db.VarChar(200)
  slug             String        @unique @db.VarChar(100)
  content          String        @db.LongText
  isPublished      Boolean       @default(true) @map("is_published")
  updatedByAdminId String?       @map("updated_by_admin_id")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  updatedBy Admin? @relation(fields: [updatedByAdminId], references: [id])

  @@map("legal_pages")
}

// ─────────────────────────────────────────────
// AUDIT + SECURITY
// ─────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  actorAdminId  String?     @map("actor_admin_id")
  action        AuditAction
  entityType    String?     @map("entity_type") @db.VarChar(50)
  entityId      String?     @map("entity_id") @db.VarChar(100)
  metadataJson  String?     @map("metadata_json") @db.Text
  ipAddressHash String?     @map("ip_address_hash") @db.VarChar(255)
  userAgentHash String?     @map("user_agent_hash") @db.VarChar(255)
  createdAt     DateTime    @default(now()) @map("created_at")

  actor Admin? @relation(fields: [actorAdminId], references: [id])

  @@index([actorAdminId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model SecurityEvent {
  id            String            @id @default(cuid())
  eventType     SecurityEventType @map("event_type")
  severity      SecuritySeverity
  actorAdminId  String?           @map("actor_admin_id")
  ipAddressHash String?           @map("ip_address_hash") @db.VarChar(255)
  metadataJson  String?           @map("metadata_json") @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")

  actor Admin? @relation(fields: [actorAdminId], references: [id])

  @@index([eventType, createdAt])
  @@map("security_events")
}
