# ─────────────────────────────────────────────────────────────────────────────
# DRIP TO YOU Bali — Next.js Environment Variables
# Salin file ini ke .env.local untuk development, atau isi di Vercel dashboard.
#
# ARSITEKTUR PRODUKSI (setelah dripstoyou.com → Vercel):
#   Frontend  : https://dripstoyou.com       → Vercel (Next.js)
#   PHP API   : https://api.dripstoyou.com   → cPanel hosting (subdomain)
#
# URL gambar di database TETAP: https://dripstoyou.com/php-api/uploads/products/...
# Vercel otomatis mem-proxy /php-api/* ke api.dripstoyou.com (lihat next.config.ts).
# php-api/config.php di cPanel: UPLOAD_BASE_URL tidak perlu diubah.
# ─────────────────────────────────────────────────────────────────────────────

# ── PHP Backend URL (server-side only, WAJIB diset di Vercel) ─────────────────
# URL langsung ke cPanel hosting — BUKAN dripstoyou.com (itu sekarang Vercel).
# Setup: buat subdomain api.dripstoyou.com di DNS + cPanel → folder php-api/
# Tidak ada trailing slash.
PHP_BACKEND_URL="https://api.dripstoyou.com"

# ── PHP API Public URL (untuk referensi publik, gambar, dsb) ─────────────────
# URL publik folder php-api — tetap pakai dripstoyou.com/php-api.
# Nilai ini di-override oleh PHP_BACKEND_URL saat build (lihat next.config.ts).
# Untuk development lokal tanpa subdomain: http://localhost/php-api (XAMPP/Laragon)
# Tidak ada trailing slash.
NEXT_PUBLIC_API_BASE_URL="https://dripstoyou.com/php-api"

# ── Admin Session (iron-session) ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Minimal 32 karakter. Rahasia, jangan commit ke Git.
SESSION_SECRET="ganti-dengan-string-acak-minimal-32-karakter"

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Format: 628xxxxxxxxxx (tanpa + atau spasi)
NEXT_PUBLIC_WHATSAPP_NUMBER="6281200000000"

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://dripstoyou.com"

# ── Anthropic API (auto-translate konten admin ke bahasa aktif website) ────────
# Dapatkan di: https://console.anthropic.com/settings/keys
# Jika tidak diset, fitur auto-translate dinonaktifkan.
ANTHROPIC_API_KEY="sk-ant-..."
