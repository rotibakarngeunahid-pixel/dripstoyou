# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/dripstoyou"

# ─────────────────────────────────────────────
# SESSION (iron-session)
# Generate: openssl rand -base64 32
# Must be at least 32 chars
# ─────────────────────────────────────────────
SESSION_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# ─────────────────────────────────────────────
# FIELD ENCRYPTION (AES-256-GCM)
# Generate: openssl rand -hex 32  (produces 64-char hex = 32 bytes)
# Used to encrypt: phone numbers, addresses, notes, MFA secrets
# ─────────────────────────────────────────────
FIELD_ENCRYPTION_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"

# ─────────────────────────────────────────────
# WHATSAPP
# WHATSAPP_NUMBER: server-side (used in seed + server components)
# NEXT_PUBLIC_WHATSAPP_NUMBER: client-side (used in client components like booking page)
# Both should be the same value: format 628xxxxxxxxxx (no + or spaces)
# ─────────────────────────────────────────────
WHATSAPP_NUMBER="6281200000000"
NEXT_PUBLIC_WHATSAPP_NUMBER="6281200000000"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://dripstoyou.com"
NEXT_PUBLIC_APP_NAME="DRIP TO YOU Bali"
NODE_ENV="production"

# ─────────────────────────────────────────────
# UPLOADS
# Storage path for uploaded files (relative to project root)
# ─────────────────────────────────────────────
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB="5"
