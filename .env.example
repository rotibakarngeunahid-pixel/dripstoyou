# ─────────────────────────────────────────────────────────────────────────────
# DRIP TO YOU Bali — Next.js Environment Variables
# Salin file ini ke .env.local untuk development, atau isi di Vercel dashboard.
#
# ARSITEKTUR PRODUKSI:
#   Frontend : https://dripstoyou.com       → Vercel (Next.js)
#   PHP API  : https://api.dripstoyou.com   → cPanel hosting (subdomain baru)
#
#   Setup subdomain api.dripstoyou.com:
#     1. Di DNS manager, tambahkan A record: api.dripstoyou.com → IP server cPanel
#     2. Di cPanel, buat subdomain api.dripstoyou.com → public_html/php-api/
#     3. Aktifkan AutoSSL / Let's Encrypt untuk api.dripstoyou.com di cPanel
#     4. Update UPLOAD_BASE_URL di php-api/config.php → https://api.dripstoyou.com
#     5. Set NEXT_PUBLIC_API_BASE_URL di Vercel → https://api.dripstoyou.com
#     6. Trigger redeploy Vercel (env var NEXT_PUBLIC_ butuh rebuild)
#
#   PENTING: Jangan gunakan https://dripstoyou.com/... sebagai API URL.
#   dripstoyou.com sekarang → Vercel, bukan cPanel. Menggunakannya akan
#   membuat Vercel memanggil dirinya sendiri dan diblokir dengan 403.
# ─────────────────────────────────────────────────────────────────────────────

# ── PHP API URL ───────────────────────────────────────────────────────────────
# URL root folder php-api/ yang sudah diupload ke cPanel.
# Setelah setup subdomain: https://api.dripstoyou.com
# Development lokal: http://localhost/php-api  (jika pakai XAMPP/Laragon)
# PENTING: tidak ada trailing slash.
NEXT_PUBLIC_API_BASE_URL="https://api.dripstoyou.com"

# ── Admin Session (iron-session) ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Minimal 32 karakter. Rahasia, jangan commit ke Git.
SESSION_SECRET="ganti-dengan-string-acak-minimal-32-karakter"

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Format: 628xxxxxxxxxx (tanpa + atau spasi)
NEXT_PUBLIC_WHATSAPP_NUMBER="6281200000000"

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://dripstoyou.com"

# ── Anthropic API (auto-translate konten admin ke bahasa aktif website) ────────
# Dapatkan di: https://console.anthropic.com/settings/keys
# Jika tidak diset, fitur auto-translate dinonaktifkan (konten tetap tampil dalam bahasa asli).
ANTHROPIC_API_KEY="sk-ant-..."
